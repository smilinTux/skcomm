# SKComm Environment Variables
# Copy to .env and fill in values for your deployment.

# --- TURN Server (WebRTC relay) ---
# HMAC secret for generating time-limited TURN credentials (coturn).
# Required for WebRTC P2P connections through NAT/firewalls.
# SKCOMM_TURN_SECRET=

# TURN server URL (default: turn:turn.skworld.io:3478)
# SKCOMM_TURN_URL=turn:turn.skworld.io:3478

# --- CapAuth Validation ---
# Remote CapAuth API URL for token validation.
# Leave unset for local-only validation (default).
# CAPAUTH_API_URL=

# --- WebRTC Signaling ---
# WebSocket URL for the WebRTC signaling relay.
# SKCOMM_SIGNALING_URL=wss://ws.weblink.skworld.io

# --- Development ---
# Enable dev-mode auth bypass (skips CapAuth token checks).
# Only for local development — never set in production.
# SKCOMM_DEV_AUTH=false
